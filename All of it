# Izveido motora tilpumu izvēles sarakstu lietotāja filtriem.
def build_engine_values():
    """Izveido motora tilpuma izvēles sarakstu no 0.5 līdz 5.0."""
    values = [""]
    current = Decimal("0.5")
    while current <= Decimal("5.0"):
        values.append(f"{current:.1f}")
        current += Decimal("0.2")
    if values[-1] != "5.0":
        values.append("5.0")
    return values


