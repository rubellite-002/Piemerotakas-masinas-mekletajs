    # Pārzīmē tabulu ar pašreizējo rezultātu sarakstu.
    def populate_tree(self):
        """Pārzīmē tabulu ar pašreizējo rezultātu sarakstu."""
        for item in self.tree.get_children():
            self.tree.delete(item)

        for result in self.results:
            self.tree.insert(
                "",
                "end",
                values=(
                    self.display_value(result.links, allow_empty=True),
                    self.display_value(result.modelis_marka),
                    self.display_value(result.gads),
                    self.display_value(result.motors),
                    self.display_value(result.rajons),
                    self.display_value(result.apskate_deriga),
                    self.display_value(result.nakama_ta),
                ),
            )

    # Aizvieto tukšās vērtības ar saprotamu attēlojumu tabulā.
    def display_value(self, value, allow_empty=False):
        """Aizvieto tukšas vērtības ar saprotamu tekstu tabulā."""
        text = normalize_text(value)
        if text:
            return text
        return "" if allow_empty else " - "

    # Sakārto rezultātu sarakstu pēc lietotāja izvēlētā kritērija.
    def apply_sort(self, _event=None):
        """Sakārto tabulu pēc lietotāja izvēlētā kritērija."""
        choice = self.sort_var.get()
        if choice == "Bez kārtošanas":
            self.results = list(self.original_results)
        elif choice == "Gads: no mazākā uz lielāko":
            self.results = sorted(self.results, key=self.sort_year_key)
        elif choice == "Gads: no lielākā uz mazāko":
            self.results = sorted(self.results, key=self.sort_year_key, reverse=True)
        elif choice == "Motors: no mazākā uz lielāko":
            self.results = sorted(self.results, key=lambda result: self.sort_motor_value(result.motors))
        elif choice == "Motors: no lielākā uz mazāko":
            self.results = sorted(self.results, key=lambda result: self.sort_motor_value(result.motors), reverse=True)
        elif choice == "Modelis: no A līdz Z":
            self.results = sorted(self.results, key=lambda result: self.sort_model_value(result.modelis_marka))
        elif choice == "Modelis: no Z līdz A":
            self.results = sorted(self.results, key=lambda result: self.sort_model_value(result.modelis_marka), reverse=True)
        self.populate_tree()

    # Izvelk gadu no teksta kā skaitli.
    def sort_year_value(self, year_text):
        """Izvelk tikai gada skaitlisko daļu no teksta."""
        match = re.search(r"\d{4}", normalize_text(year_text))
        return int(match.group(0)) if match else -1

    # Izvelk motora tilpuma skaitlisko daļu kārtošanai.
    def sort_motor_value(self, motor_text):
        """Izvelk motora tilpuma skaitlisko daļu kārtošanai."""
        value = numeric_part(motor_text)
        return float(value) if value is not None else -1.0

    # Izveido kombinētu atslēgu kārtošanai pēc gada, mēneša un modeļa.
    def sort_year_key(self, result):
        """Izveido kārtošanas atslēgu pēc gada, mēneša un modeļa."""
        year_value, month_value = self.sort_year_month_value(result.gads)
        model_key = self.sort_model_value(result.modelis_marka)
        return (year_value, month_value, model_key)

    # Atpazīst gadu un mēnesi no gada teksta, ja mēnesis ir norādīts.
    def sort_year_month_value(self, year_text):
        """Atpazīst gadu un mēnesi no `Gads` lauka teksta."""
        text = simplify_for_match(year_text)
        year_match = re.search(r"\d{4}", text)
        year_value = int(year_match.group(0)) if year_match else -1

        month_order = {
            "janvaris": 1,
            "februaris": 2,
            "marts": 3,
            "aprilis": 4,
            "maijs": 5,
            "junijs": 6,
            "julijs": 7,
            "augusts": 8,
            "septembris": 9,
            "oktobris": 10,
            "novembris": 11,
            "decembris": 12,
        }
        for month_name, month_value in month_order.items():
            if month_name in text:
                return year_value, month_value

        return year_value, -1

    # Pārvērš datuma tekstu `(gads, mēnesis)` formā kārtošanai.
    def sort_month_year_value(self, date_text):
        """Pārvērš datuma tekstu `(gads, mēnesis)` formā kārtošanai."""
        text = normalize_text(date_text)
        match = re.search(r"(\d{2})[./-](\d{2})[./-](\d{4})", text)
        if match:
            month = int(match.group(2))
            year = int(match.group(3))
            return year, month

        match = re.search(r"(\d{1,2})[./-](\d{4})", text)
        if match:
            month = int(match.group(1))
            year = int(match.group(2))
            return year, month

        return -1, -1

    # Kārto modeļus dabiski, vispirms pēc cipariem un tad pēc teksta.
    def sort_model_value(self, model_text):
        """Kārto modeli dabiski: vispirms cipari, tad burti, ignorējot lielos burtus."""
        tokens = re.findall(r"\d+|[A-ZĀČĒĢĪĶĻŅŠŪŽ]+", normalize_text(model_text).upper())
        key = []
        for token in tokens:
            if token.isdigit():
                key.append((0, int(token)))
            else:
                key.append((1, token.casefold()))
        return key

    # Atgriež šobrīd atlasītās tabulas rindas vērtības.
    def selected_values(self):
        """Atgriež lietotāja izvēlētās tabulas rindas vērtības."""
        selected = self.tree.selection()
        if not selected:
            return None
        return self.tree.item(selected[0], "values")

    # Nokopē izvēlētās rindas linku starpliktuvē.
    def copy_selected_link(self):
        """Nokopē atlasītās rindas sludinājuma linku starpliktuvē."""
        values = self.selected_values()
        if not values:
            messagebox.showwarning("Brīdinājums", "Izvēlies rindu, kuras linku kopēt.", parent=self)
            return
        self.clipboard_clear()
        self.clipboard_append(values[0])
        messagebox.showinfo("Informācija", "Links nokopēts starpliktuvē.", parent=self)

    # Atver izvēlētās rindas sludinājumu pārlūkā.
    def open_selected_link(self, _event=None):
        """Atver atlasītās rindas sludinājumu pārlūkā."""
        values = self.selected_values()
        if values:
            open_url(values[0])


class SSApp:
    """Galvenā Tkinter lietotne, kas vada ievadi, progresu un rezultātu logus."""
    # Inicializē galveno logu un programmas mainīgos.
    def __init__(self):
        """Inicializē galveno logu un programmas stāvokli."""
        self.root = tk.Tk()
        self.root.title("SS.com auto meklētājs")
        self.root.geometry("520x560")
        self.root.resizable(False, False)

        self.queue = queue.Queue()
        self.current_frame = None
        self.progress_window = None
        self.progress_var = tk.StringVar(value="Gaida ievadi.")
        self.brand_var = tk.StringVar(value="")
        self.filter_widgets = {}

        self.show_brand_screen()
        self.root.after(200, self.poll_queue)

    # Palaiž Tkinter notikumu cilpu.
    def run(self):
        """Palaiž Tkinter notikumu cilpu."""
        self.root.mainloop()

    # Notīra iepriekšējo satura rāmi pirms nākamā skata parādīšanas.
    def clear_current_frame(self):
        """Noņem iepriekšējo satura rāmi pirms nākamā soļa parādīšanas."""
        if self.current_frame is not None:
            self.current_frame.destroy()

    # Parāda pirmo soli, kur lietotājs izvēlas auto marku.
    def show_brand_screen(self):
        """Parāda pirmo logu, kur lietotājs izvēlas auto marku."""
        self.clear_current_frame()
        frame = tk.Frame(self.root, padx=20, pady=20)
        frame.pack(fill="both", expand=True)
        self.current_frame = frame

        tk.Label(frame, text="SS.com auto meklētājs", font=("Arial", 16, "bold")).pack(pady=(10, 5))
        tk.Label(frame, text="1. solis: izvēlies automašīnas marku").pack(pady=(0, 15))

        list_frame = tk.Frame(frame)
        list_frame.pack(fill="both", expand=True)
        scrollbar = ttk.Scrollbar(list_frame, orient="vertical")
        self.brand_listbox = tk.Listbox(
            list_frame,
            exportselection=False,
            yscrollcommand=scrollbar.set,
            height=20,
            width=32,
        )
        scrollbar.config(command=self.brand_listbox.yview)
        scrollbar.pack(side="right", fill="y")
        self.brand_listbox.pack(side="left", fill="both", expand=True)

        for brand in MARKAS[1:]:
            self.brand_listbox.insert(tk.END, brand)

        tk.Button(frame, text="Tālāk", width=16, command=self.handle_brand_next).pack(pady=16)
        self.brand_listbox.bind("<Double-1>", lambda _event: self.handle_brand_next())
        self.brand_listbox.bind("<Return>", lambda _event: self.handle_brand_next())

    # Apstrādā markas izvēli un pāriet uz filtru logu.
    def handle_brand_next(self):
        """Pārbauda markas izvēli un pāriet uz filtru logu."""
        selected = self.brand_listbox.curselection()
        if not selected:
            messagebox.showwarning("Brīdinājums", "Lūdzu, izvēlies marku.")
            return
        self.brand_var.set(self.brand_listbox.get(selected[0]))
        self.show_filters_screen()

    # Parāda filtru ievades logu izvēlētajai markai.
    def show_filters_screen(self):
        """Parāda logu, kur lietotājs ievada meklēšanas filtrus."""
        self.clear_current_frame()
        frame = tk.Frame(self.root, padx=20, pady=20)
        frame.pack(fill="both", expand=True)
        self.current_frame = frame

        tk.Label(frame, text=f"2. solis: filtri markai {self.brand_var.get()}", font=("Arial", 14, "bold")).pack(pady=(0, 15))

        form = tk.Frame(frame)
        form.pack(fill="x")
        vcmd = (self.root.register(only_digits_or_empty), "%P")

        self.add_entry_row(form, 0, "Cena no:", "cena_no", vcmd)
        self.add_entry_row(form, 1, "Cena līdz:", "cena_lidz", vcmd)
        self.add_combo_row(form, 2, "Gads no:", "gads_no", GADI, width=14)
        self.add_combo_row(form, 3, "Gads līdz:", "gads_lidz", GADI, width=14)
        self.add_combo_row(form, 4, "Tilpums no:", "tilpums_no", TILPUMI, width=14)
        self.add_combo_row(form, 5, "Tilpums līdz:", "tilpums_lidz", TILPUMI, width=14)
        self.add_combo_row(form, 6, "Dzinējs:", "dzinejs", DZINEJI)
        self.add_combo_row(form, 7, "Ātrumkārba:", "atrumkarba", ATRUMKARBAS)
        self.add_combo_row(form, 8, "Rajons:", "rajons", RAJONI, width=24)

        buttons = tk.Frame(frame)
        buttons.pack(fill="x", pady=20)
        tk.Button(buttons, text="Atpakaļ", width=14, command=self.show_brand_screen).pack(side="left")
        tk.Button(buttons, text="Meklēt", width=14, command=self.start_search).pack(side="right")

    # Pievieno formai teksta ievades rindu.
    def add_entry_row(self, parent, row, label, key, validate_command):
        """Pievieno formai teksta ievades rindu ar validāciju."""
        tk.Label(parent, text=label, width=16, anchor="w").grid(row=row, column=0, sticky="w", pady=6)
        entry = tk.Entry(parent, validate="key", validatecommand=validate_command, width=18)
        entry.grid(row=row, column=1, sticky="w")
        self.filter_widgets[key] = entry

    # Pievieno formai dropdown izvēles rindu.
    def add_combo_row(self, parent, row, label, key, values, width=18):
        """Pievieno formai dropdown izvēles rindu."""
        tk.Label(parent, text=label, width=16, anchor="w").grid(row=row, column=0, sticky="w", pady=6)
        combo = ttk.Combobox(parent, values=values, state="readonly", width=width)
        combo.grid(row=row, column=1, sticky="w")
        combo.set("")
        self.filter_widgets[key] = combo

    # Savāc visas ievades un izveido SearchFilters objektu.
    def build_filters(self):
        """Savāc visas lietotāja ievades un izveido SearchFilters objektu."""
        values = {key: widget.get().strip() for key, widget in self.filter_widgets.items()}
        return SearchFilters(marka=self.brand_var.get(), **values)

    # Pārbauda, vai lietotāja ievadītie filtri ir loģiski derīgi.
    def validate_filters(self, filters):
        """Pārbauda, vai filtru ievades ir loģiskas un savstarpēji saderīgas."""
        if not filters.marka:
            return "Marka nav izvēlēta."
        if filters.cena_no and filters.cena_lidz and int(filters.cena_no) > int(filters.cena_lidz):
            return "Cena no nedrīkst būt lielāka par cenu līdz."
        if filters.gads_no and filters.gads_lidz and int(filters.gads_no) > int(filters.gads_lidz):
            return "Gads no nedrīkst būt lielāks par gadu līdz."
        tilpums_no = to_decimal(filters.tilpums_no)
        tilpums_lidz = to_decimal(filters.tilpums_lidz)
        if tilpums_no and tilpums_lidz and tilpums_no > tilpums_lidz:
            return "Tilpums no nedrīkst būt lielāks par tilpumu līdz."
        return None

    # Palaiž meklēšanu fonā pēc validācijas.
    def start_search(self):
        """Palaiž meklēšanu fonā pēc filtru validācijas."""
        filters = self.build_filters()
        error = self.validate_filters(filters)
        if error:
            messagebox.showwarning("Brīdinājums", error)
            return
        self.show_progress_window()
        worker = threading.Thread(target=self.search_worker, args=(filters,), daemon=True)
        worker.start()

    # Parāda nelielu progresu logu, kamēr Selenium strādā.
    def show_progress_window(self):
        """Parāda mazo progresu logu, kamēr Selenium strādā fonā."""
        if self.progress_window and self.progress_window.winfo_exists():
            self.progress_window.destroy()

        self.progress_window = tk.Toplevel(self.root)
        self.progress_window.title("Meklēšana")
        self.progress_window.geometry("420x140")
        self.progress_window.resizable(False, False)
        self.progress_window.transient(self.root)
        self.progress_window.grab_set()

        tk.Label(
            self.progress_window,
            text="Programma šobrīd strādā ar SS.com un CSDD.",
            font=("Arial", 11, "bold"),
        ).pack(pady=(20, 10))
        tk.Label(
            self.progress_window,
            textvariable=self.progress_var,
            wraplength=360,
            justify="left",
        ).pack(padx=20)

    # Fona pavedienā izpilda skrāpēšanu un nosūta rezultātus uz UI.
    def search_worker(self, filters):
        """Fona pavedienā izpilda skrāpēšanu un nosūta rezultātu ziņas rindā."""
        scraper = SSCarScraper(
            progress_callback=lambda text: self.queue.put(("progress", text)),
            manual_verification_callback=self.request_manual_verification,
        )
        try:
            results = scraper.run(filters)
            self.queue.put(("success", results))
        except NoResultsError as error:
            self.queue.put(("empty", str(error)))
        except ManualVerificationRequiredError as error:
            self.queue.put(("error", str(error)))
        except WebDriverException as error:
            self.queue.put(("error", f"Neizdevās palaist Selenium vai Chrome: {error}"))
        except Exception as error:
            self.queue.put(("error", str(error)))

    # No fona pavediena pieprasa manuālu CAPTCHA apstiprinājumu.
    def request_manual_verification(self, message):
        """No fona pavediena pieprasa lietotājam manuāli apstiprināt CAPTCHA soli."""
        event = threading.Event()
        response = {"continue": False}
        self.queue.put(("captcha", {"message": message, "event": event, "response": response}))
        event.wait()
        return response["continue"]

    # Parāda lietotājam verifikācijas dialogu un nodod atbildi atpakaļ workerim.
    def handle_manual_verification(self, payload):
        """Parāda dialogu lietotājam un nodod viņa atbildi atpakaļ worker pavedienam."""
        self.progress_var.set("Gaida manuālu verifikāciju SS.com lapā.")
        parent = self.progress_window if self.progress_window and self.progress_window.winfo_exists() else self.root
        should_continue = messagebox.askokcancel(
            "Nepieciešama verifikācija",
            payload["message"],
            parent=parent,
        )
        payload["response"]["continue"] = should_continue
        payload["event"].set()

    # Regulāri nolasa ziņu rindu un atjauno lietotāja interfeisu.
    def poll_queue(self):
        """Regulāri nolasa ziņu rindu un atjauno Tkinter interfeisu."""
        try:
            while True:
                message_type, payload = self.queue.get_nowait()
                if message_type == "progress":
                    self.progress_var.set(payload)
                elif message_type == "success":
                    self.close_progress_window()
                    ResultsWindow(self.root, payload)
                elif message_type == "empty":
                    self.close_progress_window()
                    messagebox.showinfo("Rezultātu nav", payload)
                elif message_type == "captcha":
                    self.handle_manual_verification(payload)
                elif message_type == "error":
                    self.close_progress_window()
                    messagebox.showerror("Kļūda", payload)
        except queue.Empty:
            pass
        self.root.after(200, self.poll_queue)

    # Aizver progresu logu un atiestata statusa tekstu.
    def close_progress_window(self):
        """Aizver progresu logu un atiestata statusa tekstu."""
        if self.progress_window and self.progress_window.winfo_exists():
            self.progress_window.grab_release()
            self.progress_window.destroy()
        self.progress_window = None
        self.progress_var.set("Gaida ievadi.")


if __name__ == "__main__":
    SSApp().run()
