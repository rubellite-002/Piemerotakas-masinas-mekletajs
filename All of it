class SSCarScraper:
    """Vada visu Selenium darbu no SS.com filtru ievades līdz CSDD pārbaudei."""
    # Inicializē skrāpētāja stāvokli un saziņas callback funkcijas.
    def __init__(self, progress_callback, manual_verification_callback=None):
        """Sagatavo skrāpētāju un callback funkcijas saziņai ar Tkinter logu."""
        self.progress_callback = progress_callback
        self.manual_verification_callback = manual_verification_callback
        self.driver = None
        self.wait = None
        self.csdd_tab = None
        self.ss_tab = None
        self.found_listing_links = 0

    # Nosūta īsu progresa ziņu lietotāja interfeisam.
    def report(self, text):
        """Nosūta lietotāja logam īsu statusa ziņu par notiekošo darbu."""
        self.progress_callback(text)

    # Pārbauda, vai SS.com lapā ir redzams konkrētais CAPTCHA logs.
    def page_requires_manual_verification(self):
        """Pārbauda, vai SS.com lapā ir redzams konkrētais CAPTCHA popup."""
        try:
            elements = self.driver.find_elements(By.ID, "win_alert_dv_recaptcha")
            if any(element.is_displayed() for element in elements):
                return True
        except Exception:
            pass

        return False

    # Ja nepieciešams, aptur plūsmu un gaida manuālu CAPTCHA apstiprinājumu.
    def wait_for_manual_verification(self, context):
        """Ja vajag, aptur skrāpēšanu un gaida, kamēr lietotājs izpilda CAPTCHA."""
        if "pēc pogas" not in context:
            return
        current_vin = extract_vin_from_soup(BeautifulSoup(self.driver.page_source, "html.parser"))
        if current_vin:
            return
        if not self.page_requires_manual_verification():
            return
        if not self.manual_verification_callback:
            raise ManualVerificationRequiredError("Nepieciešama manuāla verifikācija SS.com lapā.")

        self.report("Gaida manuālu verifikāciju SS.com lapā.")
        prompt = (
            f"SS.com pieprasa verifikāciju {context}.\n"
            "Pabeidz to pārlūkā un nospied 'Turpināt'."
        )
        if self.page_requires_manual_verification():
            should_continue = self.manual_verification_callback(prompt)
            if not should_continue:
                raise ManualVerificationRequiredError("Meklēšana tika atcelta verifikācijas laikā.")
            time.sleep(TAB_SWITCH_WAIT_SECONDS)
            self.wait_for_page_ready()

    # Palaiž Chrome pārlūku un sagatavo Selenium darbam.
    def create_driver(self):
        """Palaiž Chrome pārlūku un sagatavo Selenium gaidīšanas objektu."""
        options = Options()
        options.add_argument("--start-maximized")
        options.add_experimental_option("excludeSwitches", ["enable-automation"])
        options.add_experimental_option("useAutomationExtension", False)
        self.driver = webdriver.Chrome(options=options)
        self.wait = WebDriverWait(self.driver, 1)
        self.ss_tab = self.driver.current_window_handle

    # Aizver pārlūku un droši beidz Selenium sesiju.
    def close(self):
        """Droši aizver pārlūku un atbrīvo Selenium resursus."""
        if self.driver:
            try:
                self.driver.quit()
            except Exception:
                pass

    # Izpilda visu meklēšanas procesu no sākuma līdz gala rezultātiem.
    def run(self, filters):
        """Izpilda pilnu meklēšanas ciklu no filtru ievades līdz rezultātiem."""
        self.create_driver()
        try:
            self.report("Atver SS.com.")
            self.driver.get(SS_URL)
            self.open_brand_page(filters.marka)
            self.apply_filters(filters)
            results = self.collect_results(filters.rajons)
            if not results and self.found_listing_links == 0:
                raise NoResultsError("Sludinājumi dotajā kategorijā nav atrasti")
            return results
        finally:
            self.close()

    # Atver izvēlētās markas lapu SS.com vietnē.
    def open_brand_page(self, marka):
        """Atver lietotāja izvēlētās markas sludinājumu lapu SS.com."""
        if not marka:
            raise ValueError("Marka nav izvēlēta.")
        self.wait.until(EC.presence_of_element_located((By.TAG_NAME, "body")))
        try:
            brand_link = self.wait.until(EC.element_to_be_clickable((By.LINK_TEXT, marka)))
            brand_link.click()
            self.wait_for_page_ready()
            return
        except TimeoutException:
            pass

        for link in self.driver.find_elements(By.TAG_NAME, "a"):
            if normalize_text(link.text).casefold() == marka.casefold():
                self.driver.execute_script("arguments[0].click();", link)
                self.wait_for_page_ready()
                return
        raise RuntimeError(f"SS.com lapā neizdevās atrast marku '{marka}'.")

    # Ievada visus lietotāja filtrus SS.com meklēšanas formā.
    def apply_filters(self, filters):
        """Ievada visus filtrus SS.com meklēšanas formā."""
        self.report("Ievada filtrus.")
        self.set_input_value(FILTER_INPUT_NAMES["cena_no"], filters.cena_no)
        self.set_input_value(FILTER_INPUT_NAMES["cena_lidz"], filters.cena_lidz)
        self.set_select_value(FILTER_SELECTS["gads_no"], filters.gads_no, prefer_lower=True)
        self.set_select_value(FILTER_SELECTS["gads_lidz"], filters.gads_lidz, prefer_lower=True)
        self.set_select_value(FILTER_SELECTS["tilpums_no"], filters.tilpums_no, prefer_lower=True)
        self.set_select_value(FILTER_SELECTS["tilpums_lidz"], filters.tilpums_lidz, prefer_lower=True)
        self.set_engine_value(FILTER_SELECTS["dzinejs"], filters.dzinejs)
        self.set_select_value(FILTER_SELECTS["atrumkarba"], filters.atrumkarba)
        if filters.rajons and filters.rajons != "Visi":
            self.set_select_value(FILTER_SELECTS["rajons"], filters.rajons)
        self.set_select_value(FILTER_SELECTS["darijuma_veids"], "Pārdod")
        self.wait_for_page_ready()
        if self.results_page_has_no_results():
            raise NoResultsError("Sludinājumi dotajā kategorijā nav atrasti")

    # Atrod teksta ievades lauku un ievada tajā vērtību.
    def set_input_value(self, possible_names, value):
        """Atrod tekstlodziņu un ievada tajā norādīto vērtību."""
        if not value:
            return
        element = self.find_first_by_names(possible_names)
        if element is None:
            return
        element.clear()
        element.send_keys(value)
        self.trigger_refresh(element)

    # Atrod select lauku un izvēlas tam atbilstošu opciju.
    def set_select_value(self, possible_names, desired_text, prefer_lower=False):
        """Atrod select lauku un iestata tuvāko atbilstošo opciju."""
        if not desired_text:
            return
        element = self.find_select_element(possible_names, desired_text)
        if element is None:
            return
        value_to_use = self.pick_best_option_text(element, desired_text, prefer_lower)
        if not value_to_use:
            return
        select = Select(element)
        for option in select.options:
            if normalize_text(option.text) == value_to_use:
                select.select_by_visible_text(option.text)
                self.trigger_refresh(element)
                return

    # Mēģina atrast select elementu pēc name vai opciju satura.
    def find_select_element(self, possible_names, desired_text):
        """Meklē select elementu pēc `name` vai pēc opciju satura."""
        wanted_variants = select_match_variants(desired_text)

        for name in possible_names:
            elements = self.driver.find_elements(By.NAME, name)
            if elements:
                return elements[0]

        for select_element in self.driver.find_elements(By.TAG_NAME, "select"):
            try:
                option_texts = [
                    simplify_for_match(option.text) for option in Select(select_element).options
                ]
                option_values = [
                    simplify_for_match(option.get_attribute("value") or "")
                    for option in Select(select_element).options
                ]
            except Exception:
                continue

            if any(
                variant and (
                    any(variant in option_text for option_text in option_texts)
                    or any(variant in option_value for option_value in option_values)
                )
                for variant in wanted_variants
            ):
                return select_element

        return self.find_first_by_names(possible_names)

    # Atsevišķi apstrādā dzinēja dropdown izvēli.
    def set_engine_value(self, possible_names, desired_text):
        """Atsevišķi apstrādā dzinēja izvēli, jo SS.com šeit teksts mēdz atšķirties."""
        if not desired_text:
            return
        element = self.find_engine_select(possible_names, desired_text)
        if element is None:
            return

        select = Select(element)
        wanted_variants = engine_match_variants(desired_text)

        for option in select.options:
            option_text = simplify_for_match(option.text)
            option_value = simplify_for_match(option.get_attribute("value") or "")
            if option_text in wanted_variants or option_value in wanted_variants:
                select.select_by_visible_text(option.text)
                self.trigger_refresh(element)
                return

        for option in select.options:
            option_text = simplify_for_match(option.text)
            option_value = simplify_for_match(option.get_attribute("value") or "")
            if any(variant and (variant in option_text or variant in option_value) for variant in wanted_variants):
                select.select_by_visible_text(option.text)
                self.trigger_refresh(element)
                return

    # Atrod tieši dzinēja select lauku.
    def find_engine_select(self, possible_names, desired_text):
        """Atrod tieši dzinēja dropdown lauku."""
        wanted_variants = engine_match_variants(desired_text)

        for name in possible_names:
            elements = self.driver.find_elements(By.NAME, name)
            if elements:
                return elements[0]

        for select_element in self.driver.find_elements(By.TAG_NAME, "select"):
            try:
                option_texts = [
                    simplify_for_match(option.text) for option in Select(select_element).options
                ]
            except Exception:
                continue
            if any(
                variant and any(variant in option_text for option_text in option_texts)
                for variant in wanted_variants
            ):
                return select_element

        return self.find_first_by_names(possible_names)

    # Izvēlas visatbilstošāko opcijas tekstu konkrētajā select laukā.
    def pick_best_option_text(self, select_element, desired_text, prefer_lower):
        """Izvēlas labāko opcijas tekstu, ko iestatīt konkrētajā select laukā."""
        desired_normalized = normalize_text(desired_text)
        desired_variants = select_match_variants(desired_text)
        options = [normalize_text(option.text) for option in Select(select_element).options]
        if desired_normalized in options:
            return desired_normalized

        desired_number = numeric_part(desired_normalized)
        if desired_number is None:
            for option in options:
                simplified_option = simplify_for_match(option)
                if option.casefold() == desired_normalized.casefold() or simplified_option in desired_variants:
                    return option
            for option in options:
                simplified_option = simplify_for_match(option)
                if any(variant and variant in simplified_option for variant in desired_variants):
                    return option
            return None

        numeric_options = []
        for option in options:
            number = numeric_part(option)
            if number is not None:
                numeric_options.append((number, option))
        if not numeric_options:
            return None

        numeric_options.sort(key=lambda item: item[0])
        lower_or_equal = [item for item in numeric_options if item[0] <= desired_number]
        if prefer_lower and lower_or_equal:
            return lower_or_equal[-1][1]
        return min(numeric_options, key=lambda item: abs(item[0] - desired_number))[1]

    # Atrod pirmo HTML elementu, kura name sakrīt ar kādu no dotajiem variantiem.
    def find_first_by_names(self, names):
        """Atrod pirmo HTML elementu, kura `name` atbilst kādam no variantiem."""
        for name in names:
            elements = self.driver.find_elements(By.NAME, name)
            if elements:
                return elements[0]
        return None

    # Ierosina lapas atjaunošanos pēc filtra maiņas.
    def trigger_refresh(self, element):
        """Pēc filtra maiņas mēģina ierosināt lapas atjaunošanos."""
        try:
            current_body = self.driver.find_element(By.TAG_NAME, "body")
        except NoSuchElementException:
            current_body = None
        try:
            element.send_keys(Keys.TAB)
        except Exception:
            pass
        self.wait_for_page_ready(previous_body=current_body)

    # Pagaida, kamēr lapa pabeidz pārlādēties.
    def wait_for_page_ready(self, previous_body=None):
        """Pagaida, līdz lapa beidz pārlādēties un kļūst lietojama nākamajam solim."""
        try:
            if previous_body is not None:
                self.wait.until(EC.staleness_of(previous_body))
        except TimeoutException:
            pass
        try:
            self.wait.until(lambda driver: driver.execute_script("return document.readyState") == "complete")
        except TimeoutException:
            pass
        time.sleep(SS_REFRESH_WAIT_SECONDS)

    # Pārbauda, vai lapā vispārīgi redzams paziņojums par neatrastiem sludinājumiem.
    def page_has_no_results(self):
        """Pārbauda vispārīgo tekstu par to, ka sludinājumi nav atrasti."""
        return "Sludinājumi dotajā kategorijā nav atrasti" in self.driver.page_source

    # Pārbauda neatrastu rezultātu paziņojumu tikai SS.com rezultātu lapā.
    def results_page_has_no_results(self):
        """Pārbauda neatrastu rezultātu paziņojumu tikai SS.com rezultātu lapās."""
        current_url = self.driver.current_url.casefold()
        if "ss.com" not in current_url or "/msg/" in current_url:
            return False
        return "SludinÄjumi dotajÄ kategorijÄ nav atrasti" in self.driver.page_source

    # Iziet cauri visām rezultātu lapām un savāc atrastos auto.
    def collect_results(self, selected_region):
        """Apstaigā visas rezultātu lapas un savāc sludinājumus no izvēlētā rajona."""
        self.report("Meklē sludinājumus visās lapās.")
        results = []
        visited_links = set()
        visited_result_pages = set()
        page_index = 1

        while True:
            self.wait_for_page_ready()
            if self.results_page_has_no_results():
                break

            results_page_url = self.driver.current_url
            canonical_page_url = canonicalize_url(results_page_url)
            if canonical_page_url in visited_result_pages:
                break
            visited_result_pages.add(canonical_page_url)
            page_links = self.collect_listing_links_from_page(selected_region)
            self.found_listing_links += len(page_links)
            next_link = self.find_next_page()
            for link in page_links:
                if link in visited_links:
                    continue
                visited_links.add(link)
                self.report(f"Apstrādā sludinājumu {len(results) + 1}.")
                car_info = self.scrape_listing_details(link, selected_region)
                if car_info:
                    results.append(car_info)

            if not next_link:
                break
            if canonicalize_url(next_link) in visited_result_pages:
                break
            page_index += 1
            self.report(f"Pāriet uz {page_index}. lapu.")
            if self.driver.current_url != results_page_url:
                self.driver.get(results_page_url)
                self.wait_for_page_ready()
            self.driver.get(next_link)

        return results

    # Savāc sludinājumu saites no vienas rezultātu lapas.
    def collect_listing_links_from_page(self, selected_region):
        """Savāc sludinājumu saites no vienas SS.com rezultātu lapas."""
        soup = BeautifulSoup(self.driver.page_source, "html.parser")
        found = []
        stop_markers = (
            "sludinajumi - citi latvijas rajoni",
            "sludinajumi - citi larvijas rajoni",
        )

        for row in soup.select("tr"):
            row_text_normalized = simplify_for_match(row.get_text(" ", strip=True))
            if any(marker in row_text_normalized for marker in stop_markers):
                break

            if not (row.get("id") or "").startswith("tr_"):
                continue

            cells_text = normalize_text(row.get_text(" ", strip=True))
            if selected_region and selected_region not in ("", "Visi") and selected_region not in cells_text:
                continue
            link = row.select_one("a[href*='/msg/']")
            if link and link.get("href"):
                found.append(urljoin(SS_URL, link["href"]))

        if found:
            return found

        for anchor in soup.select("a[href*='/msg/']"):
            href = anchor.get("href", "")
            if href:
                found.append(urljoin(SS_URL, href))
        return list(dict.fromkeys(found))

    # Atrod nākamās rezultātu lapas saiti.
    def find_next_page(self):
        """Atrod nākamās rezultātu lapas saiti, ja tāda eksistē."""
        soup = BeautifulSoup(self.driver.page_source, "html.parser")
        next_candidates = [
            soup.find("a", string=lambda text: text and "Nākamā" in text),
            soup.find("a", string=lambda text: text and "Next" in text),
            soup.select_one("a[rel='next']"),
        ]
        for candidate in next_candidates:
            if candidate and candidate.get("href"):
                return urljoin(self.driver.current_url, candidate["href"])
        return None

    # Atver vienu sludinājumu un nolasa tā datus.
    def scrape_listing_details(self, url, selected_region):
        """Atver vienu sludinājumu un nolasa tā svarīgāko informāciju."""
        if self.ss_tab and self.ss_tab in self.driver.window_handles:
            time.sleep(TAB_SWITCH_WAIT_SECONDS)
            self.driver.switch_to.window(self.ss_tab)
        self.driver.get(url)
        self.wait_for_page_ready()
        soup = BeautifulSoup(self.driver.page_source, "html.parser")
        fields = self.extract_fields_from_page(soup)
        region = fields.get("Rajons", "")
        display_region = region or (selected_region if selected_region not in ("", "Visi") else "")

        if region and selected_region and selected_region not in ("", "Visi") and selected_region not in region:
            return None

        vin = extract_valid_vin(fields.get("VIN kods", ""))
        if not vin:
            vin = self.reveal_vin_code()

        csdd_info = self.fetch_csdd_info(vin) if vin else {}
        if self.ss_tab and self.ss_tab in self.driver.window_handles:
            time.sleep(TAB_SWITCH_WAIT_SECONDS)
            self.driver.switch_to.window(self.ss_tab)
        title_text = normalize_text(soup.title.string if soup.title else "")
        model_or_brand = csdd_info.get("marka_modelis") or fields.get("Marka", "") or title_text

        return CarResult(
            links=url,
            modelis_marka=model_or_brand,
            gads=fields.get("Izlaiduma gads", ""),
            nobraukums=fields.get("Nobraukums", ""),
            motors=fields.get("Motors", ""),
            rajons=display_region,
            apskate_deriga=csdd_info.get("apskate_deriga", ""),
            nakama_ta=csdd_info.get("nakama_ta", ""),
        )

    # Izvelk standartlaukus no SS.com detaļu lapas tabulām.
    def extract_fields_from_page(self, soup):
        """No SS.com detaļu lapas tabulām izvelk standartlaukus vārdnīcas veidā."""
        data = {}
        for row in soup.select("table tr"):
            cells = row.find_all(["td", "th"])
            if len(cells) < 2:
                continue
            label = clean_label(cells[0].get_text(" ", strip=True))
            value = normalize_text(cells[1].get_text(" ", strip=True))
            if label and value and label not in data:
                data[label] = value

        alias_map = {
            "Izlaiduma gads": ["Izlaiduma gads", "Gads"],
            "Nobraukums": ["Nobraukums"],
            "Motors": ["Motors"],
            "Rajons": ["Rajons", "Pilsēta, rajons"],
            "VIN kods": ["VIN kods", "Vin kods"],
            "Marka": ["Marka", "Marka modelis"],
        }
        normalized = {}
        for target, aliases in alias_map.items():
            for alias in aliases:
                if alias in data:
                    normalized[target] = data[alias]
                    break
        return normalized

    # Mēģina atvērt un nolasīt VIN kodu no sludinājuma lapas.
    def reveal_vin_code(self):
        """Mēģina padarīt VIN redzamu un nolasīt to no sludinājuma lapas."""
        existing_vin = extract_vin_from_soup(BeautifulSoup(self.driver.page_source, "html.parser"))
        if existing_vin:
            return existing_vin

        buttons = self.driver.find_elements(
            By.XPATH,
            "//a[contains(., 'Parādīt vin kodu')] | //input[contains(@value, 'Parādīt vin kodu')]",
        )
        for button in buttons:
            try:
                time.sleep(TAB_SWITCH_WAIT_SECONDS)
                self.driver.execute_script("arguments[0].click();", button)
                time.sleep(SS_SHOW_VIN_WAIT_SECONDS)
                self.wait_for_manual_verification("pēc pogas 'Parādīt vin kodu' nospiešanas")
                soup = BeautifulSoup(self.driver.page_source, "html.parser")
                vin = extract_vin_from_soup(soup)
                if vin:
                    return vin
            except Exception:
                continue

        return extract_vin_from_soup(BeautifulSoup(self.driver.page_source, "html.parser"))

    # Pārslēdzas uz CSDD cilni vai izveido jaunu.
    def ensure_csdd_tab(self):
        """Pārslēdzas uz esošo CSDD cilni vai izveido jaunu, ja tās vēl nav."""
        if self.csdd_tab and self.csdd_tab in self.driver.window_handles:
            time.sleep(TAB_SWITCH_WAIT_SECONDS)
            self.driver.switch_to.window(self.csdd_tab)
            return
        time.sleep(TAB_SWITCH_WAIT_SECONDS)
        self.driver.switch_to.new_window("tab")
        self.csdd_tab = self.driver.current_window_handle

    # Ievada VIN CSDD sistēmā un nolasa rezultātu.
    def fetch_csdd_info(self, vin):
        """Ievada VIN CSDD lapā un nolasā pārbaudes rezultātu."""
        self.report(f"Pārbauda VIN {vin} CSDD lapā.")
        self.ensure_csdd_tab()
        self.driver.get(CSDD_URL)
        self.wait_for_page_ready()
        time.sleep(CSDD_INPUT_WAIT_SECONDS)

        vin_input = self.find_csdd_vin_input()
        if vin_input is None:
            return {}
        vin_input.clear()
        vin_input.send_keys(vin)

        submit = self.find_csdd_submit_button()
        if submit is None:
            return {}
        self.driver.execute_script("arguments[0].click();", submit)
        self.wait_for_page_ready()
        soup = BeautifulSoup(self.driver.page_source, "html.parser")
        return self.parse_csdd_page(soup)

    # Atrod CSDD VIN ievades lauku.
    def find_csdd_vin_input(self):
        """Atrod CSDD lapas VIN ievades lauku."""
        candidates = [
            (By.NAME, "vin"),
            (By.ID, "vin"),
            (By.XPATH, "//input[@type='text']"),
        ]
        for locator in candidates:
            try:
                return self.wait.until(EC.presence_of_element_located(locator))
            except TimeoutException:
                continue
        return None

    # Atrod CSDD pogu, kas sāk VIN pārbaudi.
    def find_csdd_submit_button(self):
        """Atrod CSDD pogu, kas palaiž VIN pārbaudi."""
        candidates = [
            (By.XPATH, "//button[contains(., 'Turpināt')]"),
            (By.XPATH, "//input[@type='submit' and contains(@value, 'Turpināt')]"),
            (By.XPATH, "//input[@type='submit']"),
            (By.XPATH, "//button[@type='submit']"),
        ]
        for locator in candidates:
            try:
                return self.wait.until(EC.element_to_be_clickable(locator))
            except TimeoutException:
                continue
        return None

    # Izvelk vajadzīgos datus no CSDD rezultātu lapas.
    def parse_csdd_page(self, soup):
        """No CSDD rezultātu lapas izvelk modeli, apskates datumu un derīgumu."""
        text = normalize_text(soup.get_text(" ", strip=True))
        simplified_text = simplify_for_match(text)
        data = {"marka_modelis": "", "nakama_ta": "", "apskate_deriga": ""}

        for row in soup.select("tr"):
            cells = row.find_all(["td", "th"])
            if len(cells) < 2:
                continue
            label = simplify_for_match(clean_label(cells[0].get_text(" ", strip=True)))
            value = normalize_text(cells[1].get_text(" ", strip=True))
            if not data["nakama_ta"] and re.search(r"\b\d{2}\.\d{2}\.\d{4}\b", value):
                data["nakama_ta"] = value
            if "marka" in label and "model" in label:
                data["marka_modelis"] = value
            elif "nākamās tehniskās apskates datums" in label or "tehniskās apskates datums" in label:
                data["nakama_ta"] = value

        if "nav derīga" in text.casefold() or "nederīga" in text.casefold():
            data["apskate_deriga"] = "Nav"
        elif "derīga" in text.casefold():
            data["apskate_deriga"] = "Ir"
        elif data["nakama_ta"]:
            data["apskate_deriga"] = "Ir"

        if not data["apskate_deriga"]:
            if "nav deriga" in simplified_text or "nederiga" in simplified_text:
                data["apskate_deriga"] = "Nav"
            elif "deriga" in simplified_text:
                data["apskate_deriga"] = "Ir"

        return data


class ResultsWindow(tk.Toplevel):
